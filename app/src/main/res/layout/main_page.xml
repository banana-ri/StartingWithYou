<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FFFFFF">
    <!--  Frame: Main (360x780)  -->

    <LinearLayout
        android:id="@+id/linearLayout2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="140dp"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/chevron_left"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="start|center_vertical"
            android:importantForAccessibility="no"
            android:scaleType="fitXY"
            android:src="@drawable/chevron_left" />

        <ImageView
            android:id="@+id/generated_codi_image"
            android:layout_width="315dp"
            android:layout_height="360dp" />

        <ImageButton
            android:id="@+id/chevron_right"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end|center_vertical"
            android:importantForAccessibility="no"
            android:scaleType="fitXY"
            android:src="@drawable/chevron_right" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@+id/linearLayout2"
        android:layout_alignParentStart="true"
        android:layout_marginStart="31dp"
        android:layout_marginBottom="6dp"
        android:gravity="center"
        android:text="오늘의 코디 추천"
        android:textColor="#000000"
        android:textSize="23sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/button_mycloset"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="50dp"
        android:layout_marginTop="646dp"
        android:layout_marginEnd="50dp"
        android:layout_marginBottom="45dp"
        android:background="@drawable/bg_rounded_color"
        android:gravity="center">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:importantForAccessibility="no"
                android:scaleType="fitXY"
                android:src="@drawable/archive" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:gravity="start"
                android:text="나의 옷장"
                android:textColor="#000000"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/button_addcontext"
        android:orientation="horizontal"
        android:layout_width="152dp"
        android:layout_height="39dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="52dp"
        android:layout_marginBottom="90dp"
        android:background="@drawable/bg_rounded_color"
        android:gravity="center">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal">
            <!--  INSTANCE: Plus square  -->
            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:importantForAccessibility="no"
                android:scaleType="fitXY"
                android:src="@drawable/plus" /> <!-- 이거 다시 뽑기 -->
            <!--  TEXT: 상황 더하기  -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:gravity="start"
                android:text="상황 더하기"
                android:textColor="#000000"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/button_try"
        android:orientation="horizontal"
        android:layout_width="152dp"
        android:layout_height="39dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="50dp"
        android:layout_marginBottom="91dp"
        android:background="@drawable/bg_rounded_color"
        android:gravity="center">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal">
            <!--  INSTANCE: Instagram  -->
            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:importantForAccessibility="no"
                android:scaleType="fitXY"
                android:src="@drawable/instagram" />
            <!--  TEXT: 입어보기  -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:gravity="start"
                android:text="입어보기"
                android:textColor="#000000"
                android:textSize="13sp" />

        </LinearLayout>
    </LinearLayout>

        <!--  VECTOR: Icon  -->


    <!--  INSTANCE: Chevron left  -->

    <!--  INSTANCE: Setting_Button  -->

    <!--  GROUP: Weather_Info  -->

    <!--  LINE  -->


        <!--  INSTANCE: Settings  -->
        <!--  VECTOR: Icon  -->


    <!-- 사용자 정보 수정 fab -->
    <android.support.design.widget.FloatingActionButton
        android:id="@+id/fab_sub2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@+id/fab_main"
        android:layout_alignParentRight="true"
        android:layout_marginBottom="15dp"
        android:layout_marginRight="20dp"
        android:backgroundTint="#ffffff"
        android:src="@drawable/ic_map"
        android:visibility="invisible"
        app:borderWidth="0dp"
        app:fabSize="normal" />

    <!-- 메인 fab (설정 아이콘) -->
    <android.support.design.widget.FloatingActionButton
        android:id="@+id/fab_setting_button"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="17dp"
        android:layout_marginBottom="15dp"
        android:src="@drawable/setting_button"
        app:borderWidth="0dp"
        app:fabSize="normal"/>


    <ImageView
        android:id="@+id/fab_setting_button"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="17dp"
        android:layout_marginBottom="15dp"
        android:importantForAccessibility="no"
        android:scaleType="fitXY"
        android:src="@drawable/setting_button" />

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="33dp"
        android:layout_marginTop="13dp"
        android:layout_marginEnd="33dp"
        android:layout_marginBottom="560dp"
        android:background="@drawable/rounded_border"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingTop="24dp"
        android:paddingRight="24dp"
        android:paddingBottom="24dp">
        <!--  TEXT: Text Heading  -->
        <TextView
            android:id="@+id/heading_weather"
            android:layout_width="271dp"
            android:layout_height="29dp"
            android:gravity="start"
            android:text="19°C / 11°C"
            android:textColor="#1B1B1B"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!--  FRAME: Avatar Block  -->
        <View
            android:layout_width="256dp"
            android:layout_height="1dp"
            android:background="#CECECE"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="15dp">

            <!--  RECTANGLE: 날씨 이미지  -->
            <ImageView
                android:id="@+id/weather_image"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:importantForAccessibility="no"
                android:scaleType="fitXY"
                android:src="@drawable/baseline_wb_sunny_24" />
            <!--  FRAME: 날씨 상세 정보  -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="10dp"
                android:paddingTop="10dp">
                <!--  TEXT: 날씨 총평  -->
                <TextView
                    android:id="@+id/weather_overview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:text="하루 종일 맑은 하루예요."
                    android:textColor="#767676"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <!--  TEXT: 강수 확률, 풍속  -->
                <TextView
                    android:id="@+id/weather_rain_wind"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:text="강수 확률 10% | 바람 2m/s"
                    android:textColor="#BCBCBC"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>