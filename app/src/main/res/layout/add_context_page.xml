<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!--  FRAME: Header  -->
        <RelativeLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="20dp">

            <!--  Button: Arrow left-circle  -->
            <ImageButton
                android:layout_marginStart="10dp"
                android:id="@+id/arrow_left_circle"
                android:layout_width="31dp"
                android:layout_height="31dp"
                android:background="#FFFFFFFF"
                android:src="@drawable/arrow_left_circle" />

            <!--  TEXT: 중요한 약속이 있나요?  -->
            <TextView
                android:layout_centerInParent="true"
                android:layout_gravity="center_horizontal"
                android:text="중요한 약속이 있나요?"
                android:textSize="19sp"
                android:textColor="#000000"
                android:gravity="center_horizontal"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </RelativeLayout>

        <!-- 상황 선택 -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp">

            <!-- 상황 칩-->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroup_contents"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleLine="true"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:chipSpacingHorizontal="8dp"
                android:layout_gravity="start">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_contents_wedding_guest"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="결혼식 하객룩"
                android:checked="true"
                app:chipBackgroundColor="@color/chip_bg_state"
                android:textColor="@color/chip_text_state"
                app:chipStrokeWidth="0dp"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_contents_condolences"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="장례식장 조문"
                app:chipBackgroundColor="@color/chip_bg_state"
                android:textColor="@color/chip_text_state"
                app:chipStrokeWidth="0dp"/>

                <com.google.android.material.chip.Chip
                android:id="@+id/chip_contents_interview"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="면접"
                app:chipBackgroundColor="@color/chip_bg_state"
                android:textColor="@color/chip_text_state"
                app:chipStrokeWidth="0dp"/>

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="114dp"
                android:background="@drawable/bg_rounded"
                android:orientation="vertical"
                android:paddingLeft="15dp"
                android:paddingTop="15dp"
                android:paddingRight="15dp"
                android:paddingBottom="15dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:text="이런 의상은 조심하세요!"
                    android:textColor="#FF000000"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:text=" · 슬리퍼, 트레이닝복 등의 편한 의상"
                    android:textColor="#FF000000"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:text=" · 짧거나 노출이 있는 의상"
                    android:textColor="#FF000000"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:text="다양한 지인이 모이는 자리이니 주의해야 해요."
                    android:textColor="#FF828282"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>


        <FrameLayout
            android:layout_width="334dp"
            android:layout_height="381dp"
            android:background="@drawable/bg_rounded"
            android:paddingLeft="15dp"
            android:paddingTop="15dp"
            android:paddingRight="15dp"
            android:paddingBottom="15dp">
            <LinearLayout
                android:layout_width="329dp"
                android:layout_height="355dp"/>
            <FrameLayout
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="#FFFFFFFF">
                <ImageView
                    android:src="@drawable/arrow_left_circle"
                    android:scaleType="fitXY"
                    android:layout_width="12dp"
                    android:layout_height="23dp"/>
            </FrameLayout>
            <FrameLayout
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="#FFFFFFFF">
                <ImageView
                    android:src="@drawable/arrow_left_circle"
                    android:scaleType="fitXY"
                    android:layout_width="12dp"
                    android:layout_height="23dp"/>
            </FrameLayout>
            <TextView
                android:text="이렇게 입어보세요"
                android:textSize="15sp"
                android:textColor="#FF000000"
                android:gravity="start"
                android:textStyle="bold"
                android:layout_width="117dp"
                android:layout_height="22dp"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="325dp"
            android:layout_height="39dp"
            android:background="@drawable/bg_rounded"
            android:paddingLeft="15dp"
            android:paddingTop="0dp"
            android:paddingRight="15dp"
            android:paddingBottom="0dp">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="77dp"
                android:layout_height="23dp">
                <FrameLayout
                    android:layout_width="23dp"
                    android:layout_height="23dp"
                    android:background="#FFFFFFFF">
                    <ImageView
                        android:src="@drawable/"
                        android:scaleType="fitXY"
                        android:layout_width="19dp"
                        android:layout_height="19dp"/>
                </FrameLayout>

                <TextView
                    android:layout_width="50dp"
                    android:layout_height="19dp"
                    android:gravity="start"
                    android:text="입어보기"
                    android:textColor="#FF000000"
                    android:textSize="13sp" />
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>
</RelativeLayout>