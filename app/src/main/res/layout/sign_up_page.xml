<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="사용자 정보를 입력해 주세요."
            android:textSize="15sp"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <EditText
            android:id="@+id/field_name"
            android:layout_width="314dp"
            android:layout_height="38dp"
            android:background="@drawable/rounded_border_field"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:hint="이름"
            android:textSize="13sp"
            android:textColor="#FF828282"
            android:gravity="center_vertical" />

        <LinearLayout
            android:layout_width="314dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="10dp">

            <EditText
                android:id="@+id/field_age"
                android:layout_width="130dp"
                android:layout_height="38dp"
                android:background="@drawable/rounded_border_field"
                android:hint="나이"
                android:textSize="13sp"
                android:textColor="#FF828282"
                android:inputType="number"
                android:paddingLeft="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="세"
                android:textSize="13sp"
                android:textColor="#FF000000"
                android:layout_marginHorizontal="5dp"/>

            <Spinner
                android:id="@+id/select_job"
                android:layout_width="150dp"
                android:layout_height="48dp"
                android:layout_marginLeft="10dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="314dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start"
            android:layout_marginTop="10dp">

            <EditText
                android:id="@+id/field_height"
                android:layout_width="249dp"
                android:layout_height="38dp"
                android:background="@drawable/rounded_border_field"
                android:hint="키"
                android:textSize="13sp"
                android:textColor="#FF828282"
                android:inputType="numberDecimal"
                android:paddingLeft="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="cm"
                android:textSize="13sp"
                android:textColor="#FF000000"
                android:layout_marginLeft="5dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="314dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start"
            android:layout_marginTop="10dp">

            <EditText
                android:id="@+id/field_weight"
                android:layout_width="250dp"
                android:layout_height="38dp"
                android:background="@drawable/rounded_border_field"
                android:paddingLeft="15dp"
                android:paddingRight="15dp"
                android:hint="몸무게"
                android:textSize="13sp"
                android:textColor="#FF828282"
                android:inputType="numberDecimal" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="kg"
                android:textSize="13sp"
                android:textColor="#000000"
                android:layout_marginLeft="5dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp">
            <View
                android:layout_width="130dp"
                android:layout_height="1dp"
                android:background="#FFE6E6E6"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="성별"
                android:textSize="13sp"
                android:textColor="#FF828282"
                android:layout_marginHorizontal="10dp"/>
            <View
                android:layout_width="130dp"
                android:layout_height="1dp"
                android:background="#FFE6E6E6"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="314dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button_woman"
                android:layout_width="150dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_rounded_color"
                android:text="여성"
                android:textSize="13sp"
                android:textColor="#FF000000" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button_men"
                android:layout_width="150dp"
                android:layout_height="38dp"
                android:layout_marginLeft="14dp"
                android:background="@drawable/bg_rounded_color"
                android:text="남성"
                android:textSize="13sp"
                android:textColor="#FF000000" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_other"
            android:layout_width="310dp"
            android:layout_height="38dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_rounded_color"
            android:text="그 외 / 알리고 싶지 않음"
            android:textSize="13sp"
            android:textColor="#000000" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_continue"
            android:layout_width="314dp"
            android:layout_height="38dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_rounded_button_continue"
            android:text="계속"
            android:textSize="13sp"
            android:textColor="#FFFFFFFF" />
    </LinearLayout>
</RelativeLayout>